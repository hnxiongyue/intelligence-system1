# ============================================
# LLM API Configuration (Multiple Providers)
# ============================================

# Option 1: Alibaba Bailian (Qwen) - Recommended for Chinese
LLM_API_KEY=sk-your-bailian-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Option 2: DeepSeek (Alternative)
# LLM_API_KEY=sk-your-deepseek-api-key-here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Option 3: OpenAI (Alternative)
# LLM_API_KEY=sk-your-openai-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo

# ============================================
# DingTalk Configuration
# ============================================
# Webhook Mode (Simple Push)
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token_here

# Stream Mode (Bidirectional Interaction)
# Get from: https://open-dev.dingtalk.com
DINGTALK_CLIENT_ID=your_client_id_here
DINGTALK_CLIENT_SECRET=your_client_secret_here

# ============================================
# Firecrawl API (Optional - Get from https://firecrawl.dev)
# ============================================
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ============================================
# Vector Store (Qdrant)
# ============================================
# Enable vector store for semantic deduplication and search
VECTOR_STORE_ENABLED=false

# Local mode (default)
QDRANT_PATH=./data/qdrant

# Cloud mode (optional)
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key_here

# ============================================
# Database
# ============================================
DATABASE_PATH=data/intelligence.db

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
